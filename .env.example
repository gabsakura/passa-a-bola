# =============================================================================
# Passa a Bola — variáveis de ambiente
# Copie este arquivo para `.env` e preencha com os valores do Firebase Console.
# Nunca commite o arquivo `.env` (já está no .gitignore).
#
# Deploy web:
#   .\scripts\deploy.ps1
#
# Rodar local (Chrome):
#   .\scripts\run_local.ps1
# =============================================================================

# Firebase — geral
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_STORAGE_BUCKET=seu-project-id.firebasestorage.app

# Firebase — Web
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_AUTH_DOMAIN=seu-project-id.firebaseapp.com
FIREBASE_WEB_MEASUREMENT_ID=

# Firebase — Android
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=

# Firebase — iOS
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_BUNDLE_ID=com.example.passaabola

# Google Maps (mesma chave usada no web/index.html)
GOOGLE_MAPS_API_KEY=

# API-Sports (opcional — página de teste)
APISPORTS_API_KEY=

# Alias do projeto no Firebase CLI (opcional, usado pelo deploy)
FIREBASE_PROJECT_ALIAS=default
